{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "incident": {
      "type": "string",
      "description": "Brief description of the incident"
    },
    "root_cause": {
      "type": "object",
      "properties": {
        "service": { "type": "string" },
        "operation": { "type": "string" },
        "metric_name": { "type": "string" },
        "anomaly_value": { "type": "number" },
        "threshold": { "type": "number" },
        "unit": { "type": "string" }
      }
    },
    "cascade": {
      "type": "array",
      "items": { "type": "string" },
      "description": "List of affected downstream services"
    },
    "first_seen": { "type": "string", "format": "date-time" },
    "recommendations": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Ordered list of remediation actions"
    }
  }
}