<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>RCA Report — {{ incident.service | default('Incident') }}</title>
  <style>
    /* ── Design Tokens ─────────────────────────────────────────────────────── */
    :root {
      --bg:          #f4f6fc;
      --card:        #ffffff;
      --border:      #e2e8f0;
      --text:        #1e2235;
      --muted:       #64748b;
      --heading:     #0f1117;
      --accent:      #f59e0b;
      --accent-dark: #d97706;
      --red:         #dc2626;
      --red-bg:      #fef2f2;
      --red-border:  #fca5a5;
      --orange:      #ea580c;
      --orange-bg:   #fff7ed;
      --yellow:      #d97706;
      --yellow-bg:   #fffbeb;
      --green:       #059669;
      --green-bg:    #f0fdf4;
      --green-border:#86efac;
      --blue:        #2563eb;
      --blue-bg:     #eff6ff;
      --purple:      #7c3aed;
      --indigo:      #4f46e5;
      --radius:      10px;
      --shadow:      0 1px 3px rgba(0,0,0,.07), 0 4px 16px rgba(0,0,0,.06);
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg);
      color: var(--text);
      font-size: 14px;
      line-height: 1.6;
    }

    /* ── Layout ────────────────────────────────────────────────────────────── */
    .page { max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }

    /* ── Hero header ───────────────────────────────────────────────────────── */
    .hero {
      background: linear-gradient(135deg, #1e2235 0%, #3b1f6e 60%, #f59e0b33 100%);
      border-radius: 16px;
      padding: 2.5rem 2rem;
      color: #fff;
      margin-bottom: 2rem;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute; inset: 0;
      background: radial-gradient(ellipse at 80% 50%, rgba(245,158,11,.15) 0%, transparent 60%);
      pointer-events: none;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: .4rem;
      background: rgba(245,158,11,.2);
      border: 1px solid rgba(245,158,11,.4);
      border-radius: 20px;
      padding: .2rem .75rem;
      font-size: .72rem;
      font-weight: 600;
      letter-spacing: .05em;
      text-transform: uppercase;
      color: #fcd34d;
      margin-bottom: .75rem;
    }
    .hero h1 { font-size: 1.75rem; font-weight: 700; margin-bottom: .35rem; }
    .hero-meta { display: flex; flex-wrap: wrap; gap: 1.5rem; margin-top: 1rem; opacity: .85; font-size: .82rem; }
    .hero-meta span { display: flex; align-items: center; gap: .35rem; }

    /* ── Severity pill ─────────────────────────────────────────────────────── */
    .severity-pill {
      display: inline-block;
      padding: .2rem .65rem;
      border-radius: 20px;
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
    }
    .sev-P1 { background: var(--red-bg);    color: var(--red);    border: 1px solid var(--red-border); }
    .sev-P2 { background: var(--orange-bg); color: var(--orange); border: 1px solid #fdba74; }
    .sev-P3 { background: var(--yellow-bg); color: var(--yellow); border: 1px solid #fcd34d; }
    .sev-P4 { background: var(--blue-bg);   color: var(--blue);   border: 1px solid #93c5fd; }

    /* ── Section card ──────────────────────────────────────────────────────── */
    .section {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      box-shadow: var(--shadow);
      margin-bottom: 1.5rem;
      overflow: hidden;
    }
    .section-header {
      display: flex; align-items: center; gap: .6rem;
      padding: .9rem 1.25rem;
      border-bottom: 1px solid var(--border);
      background: #fafbfd;
    }
    .section-header h2 { font-size: .95rem; font-weight: 600; color: var(--heading); }
    .section-icon { font-size: 1.1rem; }
    .section-body { padding: 1.25rem; }

    /* ── KPI row ───────────────────────────────────────────────────────────── */
    .kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; }
    .kpi {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 1rem;
      text-align: center;
    }
    .kpi-value { font-size: 2rem; font-weight: 700; color: var(--accent-dark); line-height: 1; }
    .kpi-label { font-size: .75rem; color: var(--muted); margin-top: .3rem; }

    /* ── Root cause card ───────────────────────────────────────────────────── */
    .rc-card {
      border: 2px solid var(--accent);
      border-radius: var(--radius);
      padding: 1.25rem;
      background: linear-gradient(135deg, #fffbeb 0%, #fff7ed 100%);
    }
    .rc-title { font-size: 1.05rem; font-weight: 700; color: var(--heading); margin-bottom: .5rem; }
    .rc-desc  { color: var(--text); line-height: 1.65; }
    .confidence-bar {
      margin-top: .75rem;
      display: flex; align-items: center; gap: .75rem;
    }
    .confidence-track {
      flex: 1; height: 6px; border-radius: 3px; background: #e2e8f0; overflow: hidden;
    }
    .confidence-fill {
      height: 100%; border-radius: 3px;
      background: linear-gradient(90deg, #f59e0b, #d97706);
      transition: width .4s ease;
    }
    .confidence-label { font-size: .75rem; color: var(--muted); white-space: nowrap; }

    /* ── Factor list ───────────────────────────────────────────────────────── */
    .factor-list { display: flex; flex-direction: column; gap: .6rem; }
    .factor-item {
      display: flex; align-items: flex-start; gap: .75rem;
      padding: .75rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
    }
    .factor-dot {
      width: 8px; height: 8px; border-radius: 50%;
      flex-shrink: 0; margin-top: .35rem;
    }
    .dot-high   { background: var(--red);    }
    .dot-medium { background: var(--yellow); }
    .dot-low    { background: var(--green);  }
    .factor-content { flex: 1; }
    .factor-name { font-weight: 600; font-size: .85rem; }
    .factor-desc { color: var(--muted); font-size: .82rem; margin-top: .1rem; }

    /* ── Timeline ──────────────────────────────────────────────────────────── */
    .timeline { position: relative; padding-left: 1.5rem; }
    .timeline::before {
      content: ''; position: absolute; left: .35rem; top: 0; bottom: 0;
      width: 2px; background: var(--border);
    }
    .tl-item { position: relative; margin-bottom: .85rem; }
    .tl-dot {
      position: absolute; left: -1.15rem; top: .3rem;
      width: 10px; height: 10px; border-radius: 50%;
      background: var(--accent); border: 2px solid #fff;
      box-shadow: 0 0 0 2px var(--accent);
    }
    .tl-time  { font-size: .72rem; color: var(--accent-dark); font-weight: 700; }
    .tl-event { font-size: .85rem; color: var(--text); }

    /* ── Remediation cols ──────────────────────────────────────────────────── */
    .rem-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1rem; }
    .rem-col { border: 1px solid var(--border); border-radius: 8px; overflow: hidden; }
    .rem-col-header {
      padding: .6rem .9rem;
      font-size: .75rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase;
    }
    .rem-immediate .rem-col-header { background: var(--red-bg);    color: var(--red);    }
    .rem-short     .rem-col-header { background: var(--yellow-bg); color: var(--yellow); }
    .rem-long      .rem-col-header { background: var(--green-bg);  color: var(--green);  }
    .rem-col ul { padding: .75rem .9rem .75rem 1.5rem; }
    .rem-col li { font-size: .84rem; color: var(--text); margin-bottom: .4rem; }

    /* ── Signal summary table ──────────────────────────────────────────────── */
    .sig-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: .75rem; }
    .sig-box {
      padding: .75rem 1rem;
      border: 1px solid var(--border);
      border-radius: 8px;
      background: var(--bg);
    }
    .sig-box-title { font-size: .72rem; font-weight: 700; text-transform: uppercase;
                     letter-spacing: .05em; color: var(--muted); margin-bottom: .3rem; }
    .sig-box-value { font-size: 1.4rem; font-weight: 700; color: var(--heading); }
    .sig-box-sub   { font-size: .75rem; color: var(--muted); margin-top: .1rem; }

    /* ── Alert table ───────────────────────────────────────────────────────── */
    table { width: 100%; border-collapse: collapse; font-size: .83rem; }
    th { text-align: left; padding: .5rem .75rem; background: #f8fafc;
         color: var(--muted); font-weight: 600; font-size: .72rem;
         text-transform: uppercase; letter-spacing: .04em;
         border-bottom: 1px solid var(--border); }
    td { padding: .55rem .75rem; border-bottom: 1px solid #f1f5f9; vertical-align: top; }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: #f8fafc; }

    /* ── Tag chips ─────────────────────────────────────────────────────────── */
    .chip {
      display: inline-block; padding: .15rem .5rem;
      border-radius: 12px; font-size: .72rem; font-weight: 600;
      border: 1px solid;
    }
    .chip-red    { background: var(--red-bg);    color: var(--red);    border-color: var(--red-border); }
    .chip-orange { background: var(--orange-bg); color: var(--orange); border-color: #fdba74; }
    .chip-yellow { background: var(--yellow-bg); color: var(--yellow); border-color: #fcd34d; }
    .chip-blue   { background: var(--blue-bg);   color: var(--blue);   border-color: #93c5fd; }
    .chip-green  { background: var(--green-bg);  color: var(--green);  border-color: var(--green-border); }
    .chip-gray   { background: #f1f5f9; color: var(--muted); border-color: var(--border); }

    /* ── Cascade chain ─────────────────────────────────────────────────────── */
    .cascade-chain { display: flex; flex-direction: column; gap: .35rem; }
    .cascade-link  {
      font-family: 'Consolas', 'Fira Code', monospace;
      font-size: .82rem;
      padding: .5rem .75rem;
      border-radius: 6px;
      background: var(--bg);
      border: 1px solid var(--border);
      color: var(--text);
    }
    .cascade-link:first-child { border-left: 3px solid var(--accent-dark); }

    /* ── Prevention / gaps list ────────────────────────────────────────────── */
    .gap-list { display: flex; flex-direction: column; gap: .5rem; }
    .gap-item {
      display: flex; gap: .6rem; align-items: flex-start;
      padding: .6rem .75rem;
      border: 1px solid #fde68a;
      border-radius: 8px;
      background: var(--yellow-bg);
    }
    .gap-icon { flex-shrink: 0; font-size: .9rem; }
    .gap-text { font-size: .84rem; color: var(--text); }

    /* ── Error log list ────────────────────────────────────────────────────── */
    .log-entry {
      font-family: 'Consolas', monospace;
      font-size: .77rem;
      padding: .4rem .6rem;
      border-radius: 4px;
      background: #1e2235;
      color: #e2e8f0;
      margin-bottom: .35rem;
      overflow-x: auto;
      white-space: pre-wrap;
      word-break: break-all;
    }
    .log-fatal { border-left: 3px solid var(--red);    }
    .log-error { border-left: 3px solid var(--orange); }

    /* ── Collection errors ─────────────────────────────────────────────────── */
    .err-box {
      background: var(--red-bg);
      border: 1px solid var(--red-border);
      border-radius: 8px;
      padding: .75rem;
      margin-bottom: .5rem;
      font-size: .82rem;
      color: var(--red);
      font-family: monospace;
    }

    /* ── Footer ────────────────────────────────────────────────────────────── */
    .report-footer {
      margin-top: 2.5rem;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      text-align: center;
      font-size: .75rem;
      color: var(--muted);
    }

    /* ── AI badge ──────────────────────────────────────────────────────────── */
    .ai-badge {
      display: inline-flex; align-items: center; gap: .3rem;
      background: linear-gradient(135deg, #6366f1, #8b5cf6);
      color: #fff;
      padding: .2rem .65rem;
      border-radius: 20px;
      font-size: .7rem;
      font-weight: 600;
    }

    @media (max-width: 700px) {
      .hero h1 { font-size: 1.3rem; }
      .kpi-grid { grid-template-columns: repeat(2, 1fr); }
      .rem-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>
<div class="page">

  {# ── Hero Header ─────────────────────────────────────────────────────────── #}
  <div class="hero">
    <div class="hero-badge">🔍 RCA Agent Report</div>
    <h1>{{ incident.alert_name | default('Incident Analysis') }}</h1>
    <p style="opacity:.8; margin-top:.3rem; max-width:700px">
      {{ incident.description | default('Automated root-cause analysis across all connected observability tools.') }}
    </p>
    <div class="hero-meta">
      <span>🎯 Service: <strong>{{ incident.service | default('All services') }}</strong></span>
      <span>⏱ Window: <strong>{{ incident.time_window_minutes | default(15) }} min</strong></span>
      <span>📅 Generated: <strong>{{ generated_at }}</strong></span>
      {% if rca.ai_powered %}
      <span><span class="ai-badge">✨ AI-powered</span></span>
      {% endif %}
      {% if rca.impact_assessment %}
      <span>
        <span class="severity-pill sev-{{ rca.impact_assessment.severity | default('P3') }}">
          {{ rca.impact_assessment.severity | default('P3') }}
        </span>
      </span>
      {% endif %}
    </div>
  </div>

  {# ── KPI Row ─────────────────────────────────────────────────────────────── #}
  <div class="kpi-grid" style="margin-bottom:1.5rem">
    <div class="kpi">
      <div class="kpi-value" style="color:var(--red)">{{ signals.firing_alert_count | default(0) }}</div>
      <div class="kpi-label">Firing Alerts</div>
    </div>
    <div class="kpi">
      <div class="kpi-value" style="color:var(--orange)">{{ signals.error_log_count | default(0) }}</div>
      <div class="kpi-label">Error Log Entries</div>
    </div>
    <div class="kpi">
      <div class="kpi-value" style="color:var(--yellow)">{{ signals.trace_span_count | default(0) }}</div>
      <div class="kpi-label">Trace Spans Analysed</div>
    </div>
    <div class="kpi">
      <div class="kpi-value" style="color:var(--indigo, #4f46e5)">{{ signals.unhealthy_target_count | default(0) }}</div>
      <div class="kpi-label">Unhealthy Targets</div>
    </div>
    <div class="kpi">
      <div class="kpi-value" style="color:var(--green)">{{ signals.service_count | default(0) }}</div>
      <div class="kpi-label">Services Observed</div>
    </div>
    <div class="kpi">
      <div class="kpi-value">{{ cascade.blast_radius | default(0) }}</div>
      <div class="kpi-label">Blast Radius</div>
    </div>
  </div>

  {# ── Executive Summary ───────────────────────────────────────────────────── #}
  {% if rca.executive_summary %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">📋</span>
      <h2>Executive Summary</h2>
    </div>
    <div class="section-body">
      <p style="font-size:.92rem; line-height:1.75; color:var(--text)">{{ rca.executive_summary }}</p>
    </div>
  </div>
  {% endif %}

  {# ── Root Cause ──────────────────────────────────────────────────────────── #}
  {% if rca.root_cause %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🎯</span>
      <h2>Root Cause</h2>
      {% if rca.root_cause.category %}
      <span class="chip chip-orange" style="margin-left:auto">{{ rca.root_cause.category }}</span>
      {% endif %}
    </div>
    <div class="section-body">
      <div class="rc-card">
        <div class="rc-title">{{ rca.root_cause.title }}</div>
        <div class="rc-desc">{{ rca.root_cause.description }}</div>
        {% if rca.root_cause.confidence is defined %}
        <div class="confidence-bar">
          <div class="confidence-track">
            <div class="confidence-fill" style="width:{{ (rca.root_cause.confidence * 100) | round | int }}%"></div>
          </div>
          <span class="confidence-label">{{ (rca.root_cause.confidence * 100) | round | int }}% confidence</span>
        </div>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Contributing Factors ────────────────────────────────────────────────── #}
  {% if rca.contributing_factors and rca.contributing_factors | length > 0 %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">⚠️</span>
      <h2>Contributing Factors</h2>
      <span class="chip chip-gray" style="margin-left:auto">{{ rca.contributing_factors | length }}</span>
    </div>
    <div class="section-body">
      <div class="factor-list">
        {% for f in rca.contributing_factors %}
        <div class="factor-item">
          <div class="factor-dot dot-{{ f.severity | default('medium') }}"></div>
          <div class="factor-content">
            <div class="factor-name">{{ f.factor }}</div>
            <div class="factor-desc">{{ f.description }}</div>
          </div>
          <span class="chip chip-{% if f.severity == 'high' %}red{% elif f.severity == 'low' %}green{% else %}yellow{% endif %}">
            {{ f.severity | default('medium') }}
          </span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Impact Assessment ───────────────────────────────────────────────────── #}
  {% if rca.impact_assessment %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">💥</span>
      <h2>Impact Assessment</h2>
      <span class="severity-pill sev-{{ rca.impact_assessment.severity | default('P3') }}" style="margin-left:auto">
        {{ rca.impact_assessment.severity | default('P3') }}
      </span>
    </div>
    <div class="section-body">
      <div class="sig-grid">
        <div class="sig-box">
          <div class="sig-box-title">Affected Services</div>
          <div class="sig-box-value">{{ rca.impact_assessment.affected_services | length }}</div>
          <div class="sig-box-sub">
            {% if rca.impact_assessment.affected_services %}
              {{ rca.impact_assessment.affected_services[:3] | join(', ') }}
              {% if rca.impact_assessment.affected_services | length > 3 %}+{{ rca.impact_assessment.affected_services | length - 3 }} more{% endif %}
            {% else %}Unknown{% endif %}
          </div>
        </div>
        <div class="sig-box">
          <div class="sig-box-title">Blast Radius</div>
          <div class="sig-box-value">{{ rca.impact_assessment.blast_radius | default('—') }}</div>
        </div>
        <div class="sig-box">
          <div class="sig-box-title">User Impact</div>
          <div class="sig-box-value" style="font-size:.9rem">{{ rca.impact_assessment.estimated_user_impact | default('Unknown') }}</div>
        </div>
        <div class="sig-box">
          <div class="sig-box-title">Business Impact</div>
          <div class="sig-box-value" style="font-size:.9rem">{{ rca.impact_assessment.business_impact | default('Unknown') }}</div>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Timeline ────────────────────────────────────────────────────────────── #}
  {% if rca.timeline and rca.timeline | length > 0 %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🕐</span>
      <h2>Incident Timeline</h2>
    </div>
    <div class="section-body">
      <div class="timeline">
        {% for event in rca.timeline %}
        <div class="tl-item">
          <div class="tl-dot"></div>
          <div class="tl-time">{{ event.time }}</div>
          <div class="tl-event">{{ event.event }}</div>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Cascade / Blast Radius ──────────────────────────────────────────────── #}
  {% if cascade and cascade.cascade_chain %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🌊</span>
      <h2>Service Cascade</h2>
      <span class="chip chip-red" style="margin-left:auto">Blast radius: {{ cascade.blast_radius }} service(s)</span>
    </div>
    <div class="section-body">
      <div class="cascade-chain">
        {% for link in cascade.cascade_chain %}
        <div class="cascade-link">{{ link }}</div>
        {% endfor %}
      </div>
      {% if cascade.direct_dependents or cascade.indirect_dependents %}
      <div style="margin-top:1rem; display:flex; flex-wrap:wrap; gap:.5rem">
        {% for svc in cascade.direct_dependents %}
        <span class="chip chip-orange">{{ svc }}</span>
        {% endfor %}
        {% for svc in cascade.indirect_dependents %}
        <span class="chip chip-yellow">{{ svc }}</span>
        {% endfor %}
      </div>
      <p style="margin-top:.5rem; font-size:.75rem; color:var(--muted)">
        <span class="chip chip-orange">orange</span> = direct impact &nbsp;
        <span class="chip chip-yellow">yellow</span> = transitive impact
      </p>
      {% endif %}
    </div>
  </div>
  {% endif %}

  {# ── Remediation ─────────────────────────────────────────────────────────── #}
  {% if rca.remediation %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🔧</span>
      <h2>Remediation Plan</h2>
    </div>
    <div class="section-body">
      <div class="rem-grid">
        <div class="rem-col rem-immediate">
          <div class="rem-col-header">🚨 Immediate Actions</div>
          <ul>
            {% for action in rca.remediation.immediate_actions | default([]) %}
            <li>{{ action }}</li>
            {% else %}
            <li style="color:var(--muted)">None identified</li>
            {% endfor %}
          </ul>
        </div>
        <div class="rem-col rem-short">
          <div class="rem-col-header">⚡ Short-term Fixes</div>
          <ul>
            {% for fix in rca.remediation.short_term_fixes | default([]) %}
            <li>{{ fix }}</li>
            {% else %}
            <li style="color:var(--muted)">None identified</li>
            {% endfor %}
          </ul>
        </div>
        <div class="rem-col rem-long">
          <div class="rem-col-header">🌱 Long-term Improvements</div>
          <ul>
            {% for improvement in rca.remediation.long_term_improvements | default([]) %}
            <li>{{ improvement }}</li>
            {% else %}
            <li style="color:var(--muted)">None identified</li>
            {% endfor %}
          </ul>
        </div>
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Prevention & Observability Gaps ─────────────────────────────────────── #}
  {% if rca.observability_gaps and rca.observability_gaps | length > 0 %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🔭</span>
      <h2>Observability Gaps Identified</h2>
    </div>
    <div class="section-body">
      <div class="gap-list">
        {% for gap in rca.observability_gaps %}
        <div class="gap-item">
          <span class="gap-icon">⚠</span>
          <span class="gap-text">{{ gap }}</span>
        </div>
        {% endfor %}
      </div>
    </div>
  </div>
  {% endif %}

  {# ── Raw Signal Evidence ──────────────────────────────────────────────────── #}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">📡</span>
      <h2>Signal Evidence</h2>
    </div>
    <div class="section-body">

      {# Firing Alerts #}
      {% if signals.firing_alerts_sample and signals.firing_alerts_sample | length > 0 %}
      <h3 style="font-size:.85rem; font-weight:600; color:var(--heading); margin-bottom:.5rem">
        Firing Alerts ({{ signals.firing_alert_count }})
      </h3>
      <table style="margin-bottom:1.25rem">
        <thead>
          <tr><th>Alert Name</th><th>Severity</th><th>Service</th></tr>
        </thead>
        <tbody>
          {% for alert in signals.firing_alerts_sample %}
          <tr>
            <td>{{ alert.name }}</td>
            <td>
              <span class="chip chip-{% if alert.severity in ('critical','page') %}red{% elif alert.severity == 'warning' %}yellow{% else %}blue{% endif %}">
                {{ alert.severity }}
              </span>
            </td>
            <td>{{ alert.service | default('—') }}</td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {# Slow Traces #}
      {% if signals.slow_traces_top5 and signals.slow_traces_top5 | length > 0 %}
      <h3 style="font-size:.85rem; font-weight:600; color:var(--heading); margin-bottom:.5rem">
        Slowest Traces (top {{ signals.slow_traces_top5 | length }})
      </h3>
      <table style="margin-bottom:1.25rem">
        <thead>
          <tr><th>Service</th><th>Operation</th><th>Duration (ms)</th><th>Status</th></tr>
        </thead>
        <tbody>
          {% for span in signals.slow_traces_top5 %}
          <tr>
            <td>{{ span.service }}</td>
            <td>{{ span.operation }}</td>
            <td><strong>{{ span.duration_ms }}</strong></td>
            <td>
              <span class="chip {% if span.status == 'error' %}chip-red{% else %}chip-green{% endif %}">
                {{ span.status }}
              </span>
            </td>
          </tr>
          {% endfor %}
        </tbody>
      </table>
      {% endif %}

      {# Error Logs #}
      {% if signals.error_logs_sample and signals.error_logs_sample | length > 0 %}
      <h3 style="font-size:.85rem; font-weight:600; color:var(--heading); margin-bottom:.5rem">
        Error Log Sample ({{ signals.error_log_count }} total)
      </h3>
      {% for log in signals.error_logs_sample %}
      <div class="log-entry log-{{ log.level | lower }}">{{ log.level }} | {{ log.index }} | {{ log.message }}</div>
      {% endfor %}
      {% endif %}

      {# Tool collection stats #}
      {% if signals.tool_latencies_ms %}
      <h3 style="font-size:.85rem; font-weight:600; color:var(--heading); margin:1rem 0 .5rem">
        Data Collection Latency
      </h3>
      <div class="sig-grid">
        {% for tool, ms in signals.tool_latencies_ms.items() %}
        <div class="sig-box">
          <div class="sig-box-title">{{ tool }}</div>
          <div class="sig-box-value" style="font-size:1.1rem">{{ ms }} ms</div>
        </div>
        {% endfor %}
      </div>
      {% endif %}

    </div>
  </div>

  {# ── Collection Errors ───────────────────────────────────────────────────── #}
  {% if collection_errors and collection_errors | length > 0 %}
  <div class="section">
    <div class="section-header">
      <span class="section-icon">🔴</span>
      <h2>Collection Errors</h2>
      <span class="chip chip-red" style="margin-left:auto">{{ collection_errors | length }}</span>
    </div>
    <div class="section-body">
      {% for err in collection_errors %}
      <div class="err-box">{{ err }}</div>
      {% endfor %}
      <p style="margin-top:.5rem; font-size:.8rem; color:var(--muted)">
        These errors occurred during signal collection. Analysis is based on the signals that were successfully retrieved.
      </p>
    </div>
  </div>
  {% endif %}

  {# ── Footer ──────────────────────────────────────────────────────────────── #}
  <div class="report-footer">
    Generated by <strong>Observability Studio — RCA Agent</strong> &nbsp;|&nbsp;
    {% if rca.model_used %} Model: {{ rca.model_used }} &nbsp;|&nbsp; {% endif %}
    {{ generated_at }}
    {% if not rca.ai_powered %}
    &nbsp;|&nbsp; <span style="color:var(--yellow)">⚠ AI narrative unavailable — deterministic fallback report</span>
    {% endif %}
  </div>

</div><!-- /.page -->
</body>
</html>
